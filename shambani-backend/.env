# .env - Main environment file
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL="postgresql://shamba:SHAMBANI123@localhost:5432/shambani?schema=public"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=shamba
DATABASE_PASSWORD=SHAMBANI123
DATABASE_NAME=shambani

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Bcrypt Configuration
BCRYPT_ROUNDS=10

# API Configuration
API_PREFIX=api
API_VERSION=v1

# CORS Configuration
CORS_ORIGIN="http://localhost:5173,http://localhost:3000,http://localhost:3001"
CORS_CREDENTIALS=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Email Configuration (if using)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Shambani Investment <noreply@shambani.co.tz>"

# File Upload
MAX_FILE_SIZE=5242880 # 5MB
UPLOAD_DEST=./uploads

# Redis (optional for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=