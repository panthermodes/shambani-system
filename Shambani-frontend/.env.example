# Shambani Frontend Environment Configuration Template
# Copy this file to .env and update values as needed

# Development Environment (Local Backend)
VITE_API_URL=http://localhost:3001

# Application Settings
VITE_APP_NAME=Shambani Investment
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Agricultural Value Chain Management System

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Production Configuration
# VITE_API_URL=https://shambani-backend.onrender.com
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_DEBUG=false
